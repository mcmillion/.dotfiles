# Claude Code: track only hand-authored config; ignore runtime data + secrets.
# settings.json is deliberately NOT tracked: Claude Code rewrites it at runtime,
# so it lives as a real local file at ~/.claude/settings.json and is allowed to drift.
claude/.claude/*
!claude/.claude/CLAUDE.md
!claude/.claude/statusline-command.sh
!claude/.claude/agents/
!claude/.claude/commands/
!claude/.claude/skills/
!claude/.claude/hooks/

# Symlinks to installed binaries (managed outside the repo)
bin/.local/bin/claude
bin/.local/bin/herdr
bin/.local/bin/python3.11

# ceres-specific homelab infra (hardcoded Linux paths, not portable)
bin/.local/bin/obh
bin/.local/bin/vault-git-snapshot
hunk/.config/hunk/state.json
