#!/bin/sh
# Cross-platform shim for 1Password's SSH commit signer.
# git's gpg.ssh.program points here by name (this dir is on PATH), so the
# gitconfig stays shared while the actual binary path differs per OS.
for candidate in \
  /Applications/1Password.app/Contents/MacOS/op-ssh-sign \
  /opt/1Password/op-ssh-sign
do
  if [ -x "$candidate" ]; then
    exec "$candidate" "$@"
  fi
done

echo "op-ssh-sign: 1Password signer not found in known locations" >&2
exit 1
