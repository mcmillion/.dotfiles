#!/bin/sh
mactop --headless --count 1 2>/dev/null | jq -r '
  def pad(n): tostring | until(length >= n; " " + .);
  .[0] |
  "CPU \(.cpu_usage | round | pad(3))% • MEM \(.memory.used / 1073741824 | round | pad(3))/\(.memory.total / 1073741824 | round)G • GPU \(.soc_metrics.gpu_active | round | pad(3))%"
'
