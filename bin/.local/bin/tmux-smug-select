#!/bin/bash
selected=$(smug list | fzf --reverse --header='Select smug session to start' \
    --preview='echo {}' \
    --preview-window=up:1:wrap)

[ -z "$selected" ] && exit 0

read -p "Branch (enter for default): " branch

if [ -n "$branch" ]; then
    worktree-session "$selected" "$branch"
else
    worktree-session "$selected"
fi
