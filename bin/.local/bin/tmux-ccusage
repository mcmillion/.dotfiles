#!/bin/sh
# Claude Code spend pill for the tmux status bar: today / last 7d / last 30d.
# ccusage is ~1s/call, so results are cached and refreshed in the background;
# the status bar only ever reads the cache and never blocks.

cache_dir="$HOME/.cache/tmux-ccusage"
cache="$cache_dir/spend"
lock="$cache_dir/lock"
ttl=600

refresh() {
  mkdir "$lock" 2>/dev/null || return  # another refresh already running
  d30=$(date -v-29d +%Y-%m-%d)
  d7=$(date -v-6d +%Y-%m-%d)
  d1=$(date +%Y-%m-%d)
  out=$(ccusage daily --since "$(date -v-29d +%Y%m%d)" --json 2>/dev/null | jq -r \
    --arg d1 "$d1" --arg d7 "$d7" --arg d30 "$d30" '
      def sum($d): [.daily[] | select(.period >= $d) | .totalCost] | add // 0;
      "\(sum($d1)|round) \(sum($d7)|round) \(sum($d30)|round)"
    ')
  case "$out" in
    [0-9]*) printf '%s\n' "$out" > "$cache.tmp" && mv "$cache.tmp" "$cache" ;;
  esac
  rmdir "$lock" 2>/dev/null
}

mkdir -p "$cache_dir"
bullet=$(printf '\xe2\x80\xa2')

# Spend (today / 7d / 30d), background-refreshed via ccusage.
spend=""
if command -v ccusage >/dev/null 2>&1; then
  age=$ttl
  [ -f "$cache" ] && age=$(( $(date +%s) - $(stat -f %m "$cache") ))
  [ "$age" -ge "$ttl" ] && ( refresh ) >/dev/null 2>&1 &
  if [ -f "$cache" ]; then
    read -r day wk mo < "$cache"
    spend="d \$$day $bullet w \$$wk $bullet m \$$mo"
  else
    spend="..."
  fi
fi

# Subscription rate-limit windows, forwarded from the Claude statusline hook
# (statusline-command.sh writes this cache). A window is dropped once its reset
# time passes, since the old percentage would then be stale.
rl=""
rl_cache="$cache_dir/ratelimits"
if [ -f "$rl_cache" ]; then
  read -r fp fe sp se < "$rl_cache"
  now=$(date +%s)
  if [ "$fp" != "-" ] && [ "$fe" != "-" ] && [ "$fe" -gt "$now" ]; then
    rem=$(( fe - now )); h=$(( rem / 3600 )); m=$(( (rem % 3600) / 60 ))
    if [ "$h" -gt 0 ]; then t="${h}h${m}m"; else t="${m}m"; fi
    rl="$(printf '%.0f' "$fp")% ($t)"
  fi
  if [ "$sp" != "-" ] && [ "$se" != "-" ] && [ "$se" -gt "$now" ]; then
    [ -n "$rl" ] && rl="$rl $bullet "
    rl="${rl}$(printf '%.0f' "$sp")% ($(date -r "$se" '+%b %-d'))"
  fi
fi

if [ -n "$rl" ] && [ -n "$spend" ]; then
  printf '%s %s %s' "$rl" "$bullet" "$spend"
else
  printf '%s' "$rl$spend"
fi
