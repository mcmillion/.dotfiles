#!/bin/sh
colors="blue green yellow magenta cyan red brightblue brightgreen brightyellow brightmagenta brightcyan brightred"
name=$(tmux display-message -p "#{session_name}")
if [ "$name" = "home" ]; then
  color="white"
else
  hash=$(printf '%s' "$name" | cksum | cut -d' ' -f1)
  idx=$(( (hash % 12) + 1 ))
  color=$(echo "$colors" | awk -v n="$idx" '{print $n}')
fi
tmux set -q @session_color "$color"
